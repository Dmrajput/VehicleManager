# Release signing credentials (template).
# Copy this file to "keystore.properties" (same folder) and fill in your values.
# keystore.properties is gitignored and must NEVER be committed.
#
# STORE_FILE is resolved relative to the android/app/ folder, so if you place
# the keystore at android/app/release.keystore, just use "release.keystore".

MYAPP_RELEASE_STORE_FILE=release.keystore
MYAPP_RELEASE_KEY_ALIAS=vehiclemanager
MYAPP_RELEASE_STORE_PASSWORD=CHANGE_ME
MYAPP_RELEASE_KEY_PASSWORD=CHANGE_ME
